# Copy to .env (this file is intentionally safe to commit)
#
# Never commit real API keys.

# OpenAI
OPENAI_API_KEY=
# For Azure OpenAI / compatible endpoints (optional)
# OPENAI_BASE_URL=

# Provider selection
TEK17_LLM_PROVIDER=ollama
TEK17_LLM_MODEL=llama3.2
TEK17_LLM_TEMPERATURE=0.3
# Cost control for hosted models (optional)
# TEK17_LLM_MAX_TOKENS=350

TEK17_EMBED_PROVIDER=ollama
TEK17_EMBED_MODEL=nomic-embed-text
# TEK17_OLLAMA_BASE_URL=http://localhost:11434
